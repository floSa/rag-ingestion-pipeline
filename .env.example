# =============================================================================
# RAG Assistant - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# =============================================================================

# --- MinIO (Object Storage) ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=          # openssl rand -base64 24
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=documents

# --- NebulaGraph (Knowledge Graph) ---
NEBULA_HOST=graphd
NEBULA_PORT=9669
NEBULA_USER=root
NEBULA_PASSWORD=nebula

# --- ChromaDB (Vector Database) ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# --- PostgreSQL (Dagster metadata) ---
DAGSTER_POSTGRES_USER=dagster
DAGSTER_POSTGRES_PASSWORD=    # openssl rand -base64 24
DAGSTER_POSTGRES_DB=dagster
DAGSTER_POSTGRES_HOST=postgres-dagster

# --- Embeddings ---
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# --- Docling Service ---
DOCLING_SERVICE_URL=http://docling-service:8000

# --- Pipeline (optionnel, valeurs par defaut ci-dessous) ---
# SOURCE_DIR=/opt/dagster/app/Datas
# CLEANED_SUBDIR=.cleaned
